    "nodemcu": {
      "id": "nodemcu",
      "name": "NodeMCU v2 (ESP8266)",
      "aliases": ["nodemcuv2", "esp8266", "nodemcu-v2", "amica"],
      "fqbn": "esp8266:esp8266:nodemcuv2",
      "pio_board": "nodemcuv2",
      "pio_platform": "espressif8266",
      "pio_platform_install": "pio platform install espressif8266",
      "mcu": "ESP8266 (Xtensa L106 single-core)",
      "clock_mhz": 80,
      "flash_kb": 4096,
      "ram_kb": 80,
      "eeprom_kb": 0,
      "voltage_io": 3.3,
      "upload_baud": 115200,
      "monitor_baud": 115200,
      "programmer": "raspberry_pi",
      "connectivity": ["wifi"],
      "usb_native": false,
      "pinout_file": "pinouts/nodemcu.md",
      "pins": {
        "led_builtin": 2,
        "led_builtin_active_low": true,
        "i2c_sda": 4,
        "i2c_scl": 5,
        "spi_mosi": 13,
        "spi_miso": 12,
        "spi_sck": 14,
        "spi_ss": 15,
        "uart0_tx": 1,
        "uart0_rx": 3,
        "adc_pin": "A0",
        "adc_channels": 1,
        "gpio_map": {
          "D0": 16, "D1": 5, "D2": 4, "D3": 0,
          "D4": 2,  "D5": 14,"D6": 12,"D7": 13,
          "D8": 15, "D9": 3, "D10": 1
        },
        "avoid": [],
        "boot_sensitive": [0, 2, 15],
        "no_pwm": [16],
        "no_interrupt": [16]
      },
      "notes": [
        "Usare label D0-D10 nel codice, NON i numeri GPIO diretti",
        "D4/GPIO2 = LED onboard ACTIVE LOW (LOW = acceso)",
        "D0/GPIO16: no interrupt, no PWM, no I2C — solo GPIO base + deep sleep wake",
        "D3/GPIO0 e D4/GPIO2 e D8/GPIO15: determinano boot mode",
        "Un solo ADC (A0), range 0-1V (NodeMCU Amica ha divider → 0-3.3V)",
        "ADC non funziona durante WiFi attivo",
        "Include ESP8266WiFi.h (non WiFi.h come ESP32)",
        "RAM 80KB totale, ~50KB disponibile: usare F() sempre per le stringhe",
        "Platform PlatformIO da installare sul Raspberry: pio platform install espressif8266"
      ]
    },

